# =====================================================================
# ShareK — environment template
# Copy this to `.env` and fill in your project values.
# NEVER commit the real `.env` to git.
# =====================================================================

# Your Supabase project URL (https://xxxx.supabase.co)
VITE_PUBLIC_SUPABASE_URL=

# ANON key ONLY — the client must NEVER see the service_role key.
# Found in: Supabase Dashboard → Settings → API → Project API keys → anon (public)
VITE_PUBLIC_SUPABASE_ANON_KEY=
